# Fill in only the provider you plan to use.
# AutoWiSPA loads .env from the project root automatically.

# ===== LLM API Keys =====
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# ===== Poe (poe.com) — 官方 API Key 方式 =====
POE_API_KEY=sk-poe-...
# 可选：指定 Poe 上的 Bot 名称（默认 GPT-4o）
# 常用 bot: GPT-4o / Claude-3.5-Sonnet / Gemini-2.0-Flash / claude-3-7-sonnet / claude-sonnet-4.5 /
# Minimax-M2.7 / Qwen3.6-Plus/ gemini-3-flash/ deepseek-v3.2 / Gemini-3.1-Flash-Lite / gpt-5.3-codex
POE_BOT= gpt-5.3-codex

# ===== Optional: Alternative LLM Endpoints =====
# OPENAI_BASE_URL=https://api.openai.com/v1

# ===== Semantic Scholar API (for paper retrieval) =====
SEMANTIC_SCHOLAR_API_KEY=

# ===== MLflow =====
MLFLOW_TRACKING_URI=./experiments/mlruns

# ===== Docker Sandbox (optional) =====
# DOCKER_HOST=unix:///var/run/docker.sock
